#!/usr/bin/env bash
# pre-commit hook — enforces two rules:
#   1. Local branch must be up-to-date with its remote tracking branch
#      (prevents committing on top of a stale base — "always pull before committing")
#   2. Feature branch must not have diverged from origin/main by more than
#      a configurable threshold without a recent rebase/merge
#      (encourages keeping feature branches in sync with main)
#
# Install (one-time per clone):
#   git config core.hooksPath .githooks

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # no colour

CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "HEAD")
MAIN_BRANCH="main"

# ── Fetch latest remote state quietly ─────────────────────────────────────────
# Use --quiet so the hook doesn't print noise on every commit.
# If offline or remote unreachable, warn but don't block.
if ! git fetch --quiet origin 2>/dev/null; then
  echo -e "${YELLOW}[pre-commit] WARNING: Could not reach origin — skipping remote checks.${NC}"
  exit 0
fi

# ── Rule 1: Pull before committing ────────────────────────────────────────────
# Check if the current branch has a remote tracking branch and is behind it.
TRACKING=$(git rev-parse --abbrev-ref --symbolic-full-name "@{u}" 2>/dev/null || echo "")

if [[ -n "$TRACKING" ]]; then
  BEHIND=$(git rev-list --count HEAD.."$TRACKING" 2>/dev/null || echo "0")
  if [[ "$BEHIND" -gt 0 ]]; then
    echo -e "${RED}[pre-commit] BLOCKED: Your branch is $BEHIND commit(s) behind $TRACKING.${NC}"
    echo -e "${YELLOW}  Run: git pull --rebase origin $CURRENT_BRANCH${NC}"
    echo -e "${YELLOW}  Then re-stage your changes and commit again.${NC}"
    exit 1
  fi
fi

# ── Rule 2: Feature branch must be in sync with main ──────────────────────────
# Warn (not block) when a feature branch is more than 10 commits behind main.
# Encourages regular rebases but doesn't interrupt work in progress.
DIVERGE_THRESHOLD=10

if [[ "$CURRENT_BRANCH" != "$MAIN_BRANCH" ]] && git rev-parse "origin/$MAIN_BRANCH" &>/dev/null; then
  BEHIND_MAIN=$(git rev-list --count HEAD.."origin/$MAIN_BRANCH" 2>/dev/null || echo "0")
  if [[ "$BEHIND_MAIN" -gt "$DIVERGE_THRESHOLD" ]]; then
    echo -e "${YELLOW}[pre-commit] WARNING: Branch '$CURRENT_BRANCH' is $BEHIND_MAIN commits behind origin/$MAIN_BRANCH.${NC}"
    echo -e "${YELLOW}  Consider running: git fetch origin && git rebase origin/$MAIN_BRANCH${NC}"
    echo -e "${YELLOW}  (Commit allowed — but sync soon to avoid large conflicts later.)${NC}"
  fi
fi

echo -e "${GREEN}[pre-commit] Branch checks passed.${NC}"
exit 0
